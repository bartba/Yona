# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.

# LLM provider: "openai" | "claude" | "custom"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Custom / on-premises LLM
CUSTOM_LLM_URL=http://192.168.x.x:8000
CUSTOM_LLM_KEY=
CUSTOM_LLM_CLIENT_TOKEN=
CUSTOM_LLM_MODEL_ID=
CUSTOM_LLM_USER_EMAIL=
